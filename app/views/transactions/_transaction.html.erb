<div id="<%= dom_id transaction %>">
  <div>
    <strong>Budget:</strong>
    <%= transaction.budget_id %>
  </div>

  <div>
    <strong>Name:</strong>
    <%= transaction.name %>
  </div>

  <div>
    <strong>Amount:</strong>
    <%= transaction.amount %>
  </div>

  <div>
    <strong>Due date:</strong>
    <%= transaction.due_date %>
  </div>

  <div>
    <strong>Transaction type:</strong>
    <%= transaction.transaction_type %>
  </div>

</div>
