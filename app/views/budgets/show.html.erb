<% if notice.present? %>
  <p class="notice"><%= notice %></p>
<% end %>

<%= link_to "Back to budgets", budgets_path, class: "back-link" %>

<div class="page-header">
  <h1><%= @budget.formatted_month %> Budget</h1>
  <div class="page-header__actions">
    <%= link_to "Edit", edit_budget_path(@budget), class: "btn btn-secondary" %>
    <%= button_to "Delete", @budget, method: :delete,
          data: { turbo_confirm: "Are you sure?" },
          class: "btn btn-danger" %>
    <%= link_to "Add transaction", new_budget_transaction_path(@budget), class: "btn btn-primary" %>
  </div>
</div>

<div class="summary">
  <div class="summary-card summary-card--income">
    <div class="summary-card__label">Total Income</div>
    <div class="summary-card__value"><%= number_to_currency(@budget.total_income) %></div>
  </div>
  <div class="summary-card summary-card--expense">
    <div class="summary-card__label">Total Expenses</div>
    <div class="summary-card__value"><%= number_to_currency(@budget.total_expenses) %></div>
  </div>
  <div class="summary-card summary-card--balance">
    <div class="summary-card__label">Remaining Balance</div>
    <div class="summary-card__value"><%= number_to_currency(@budget.remaining_balance) %></div>
  </div>
</div>

<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Amount</th>
        <th>Due Date</th>
        <th>Type</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @budget.transactions.each do |transaction| %>
        <tr>
          <td><%= transaction.name.capitalize %></td>
          <td><%= number_to_currency(transaction.amount) %></td>
          <td><%= transaction.formatted_due_date %></td>
          <td>
            <span class="badge <%= transaction.transaction_type == 'income' ? 'badge-income' : 'badge-expense' %>">
              <%= transaction.transaction_type.capitalize %>
            </span>
          </td>
          <td>
            <div class="td-actions">
              <%= link_to "Edit", edit_budget_transaction_path(@budget, transaction), class: "btn btn-secondary" %>
              <%= button_to "Delete", budget_transaction_path(@budget, transaction),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "btn btn-danger" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
